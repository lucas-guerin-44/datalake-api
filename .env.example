# PostgreSQL
POSTGRES_DB=datalake
POSTGRES_USER=datalake
POSTGRES_PASSWORD=datalake
POSTGRES_PORT=6543

# API
API_PORT=8000
API_URL=http://127.0.0.1

# Authentication — API keys only. See scripts/mint_api_key.py and deploy/RUNBOOK.md
# for bootstrap/rotation. There are no login or registration endpoints.

# If true, read endpoints are publicly accessible without auth.
# Defaults to false for safety - flip to true only if you intentionally want public reads.
ALLOW_PUBLIC_READS=false

# Rate limiting (slowapi). Disable by setting RATE_LIMIT_ENABLED=false.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=120/minute

# Logging (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Database URL (auto-constructed in Docker; set for local dev)
# DATABASE_URL=postgresql://datalake:datalake@localhost:6543/datalake

# MT5 bridge (Wine-hosted RPC server running alongside MT5 terminal).
# The bridge (scripts/mt5_bridge.py) is required for /ingest/refresh.
# Inside Docker the host is reachable via host.docker.internal on Linux too
# if you enable it in docker-compose (extra_hosts: ["host.docker.internal:host-gateway"]).
MT5_BRIDGE_URL=http://host.docker.internal:18812
MT5_BRIDGE_TIMEOUT=120
