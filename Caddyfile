# Caddy reverse proxy.
# Auto-TLS via Let's Encrypt — requires datalake.lucasguerin.fr A record
# pointing at this VPS and ports 80+443 open.
#
# Routing:
#   /api/*   → FastAPI container (prefix stripped before forwarding)
#   /        → static landing site container (web.Dockerfile)

{
	email luca.guer1@gmail.com
}

datalake.lucasguerin.fr {
	encode gzip zstd

	# Cap request body at 550MB (slightly above MAX_UPLOAD_SIZE_MB=500 + overhead).
	# Only enforced for the API path; the static site never accepts uploads.
	request_body {
		max_size 550MB
	}

	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		-Server
	}

	log {
		# File output so fail2ban can tail it. Also still available via
		# `docker compose logs caddy` because Caddy tees to stderr on errors.
		output file /var/log/caddy/access.log {
			roll_size 50mb
			roll_keep 5
		}
		# Redact credential-bearing query params before they're written to disk.
		# Belt-and-braces with middleware.py — the server now refuses these query
		# params entirely, but keep this so a future regression can't leak keys.
		format filter {
			wrap json
			fields {
				request>uri query {
					delete token
					delete api_key
					delete apikey
					delete access_token
					delete password
				}
			}
		}
	}

	# API — strip /api so FastAPI routes (/query, /catalog, /ingest, ...) stay
	# mounted at root inside the container.
	handle_path /api/* {
		reverse_proxy api:8000 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# Landing page — everything else falls through to the static site container.
	handle {
		reverse_proxy web:80
	}
}
