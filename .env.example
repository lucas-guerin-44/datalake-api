# PostgreSQL
POSTGRES_DB=datalake
POSTGRES_USER=datalake
POSTGRES_PASSWORD=datalake
POSTGRES_PORT=6543

# API
API_PORT=8000
API_URL=http://127.0.0.1

# Authentication
# IMPORTANT: Generate a real key before deploying:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-generate-a-real-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# If true, read endpoints are publicly accessible without auth.
ALLOW_PUBLIC_READS=true

# Logging (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Database URL (auto-constructed in Docker; set for local dev)
# DATABASE_URL=postgresql://datalake:datalake@localhost:6543/datalake
